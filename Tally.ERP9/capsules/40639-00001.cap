D20C9"><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:w w:val="120"/></w:rPr><w:t>a</w:t></w:r><w:r wsp:rsidRPr="00FD20C9"><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:w w:val="120"/></w:rPr><w:t>pplicable), Input tax paid on taxable purchases as specified in schedule II Part A, B, C, D and F or apportion of eligible input tax credit computed as per Rule 26. Input Tax Credit shall not be allowed to the dealer as per conditions laid down in sec 18(8) and Goods specified u/s 9(2).</w:t></w:r></w:p><w:p wsp:rsidR="00755430" wsp:rsidRPr="00FD20C9" wsp:rsidRDefault="00755430"><w:pPr><w:pStyle w:val="BodyText"/><w:spacing w:before="7"/><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:sz w:val="20"/></w:rPr></w:pPr></w:p><w:p wsp:rsidR="00755430" wsp:rsidRPr="00FD20C9" wsp:rsidRDefault="00755430"><w:pPr><w:pStyle w:val="BodyText"/><w:spacing w:before="7"/><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:sz w:val="20"/></w:rPr></w:pPr></w:p><w:p wsp:rsidR="00755430" wsp:rsidRPr="00FD20C9" wsp:rsidRDefault="00755430"><w:pPr><w:pStyle w:val="BodyText"/><w:spacing w:before="7"/><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:sz w:val="20"/></w:rPr></w:pPr></w:p><w:p wsp:rsidR="00755430" wsp:rsidRPr="00FD20C9" wsp:rsidRDefault="00755430"><w:pPr><w:pStyle w:val="BodyText"/><w:spacing w:before="7"/><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:sz w:val="20"/></w:rPr></w:pPr></w:p><w:p wsp:rsidR="00755430" wsp:rsidRPr="00FD20C9" wsp:rsidRDefault="00755430"><w:pPr><w:pStyle w:val="BodyText"/><w:spacing w:before="7"/><w:rPr><w:rFonts w:ascii="Calibri Light" w:h-ansi="Calibri Light"/><wx:font wx:val="Calibri Light"/><w:sz w:val="20"/></w:rPr></w:pPr></w:p>